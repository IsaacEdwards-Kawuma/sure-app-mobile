# Backend API base URL (no trailing slash).
# On a physical device you can either:
# 1. Set it here: replace localhost with your PC's IP (e.g. http://192.168.1.5:3000), then restart Expo (npx expo start --clear).
# 2. Or type the Server URL on the Login/Sign up screen — no restart needed.
# Find your PC IP: ipconfig (Windows) or ifconfig (Mac/Linux). Phone and PC must be on same Wi‑Fi.
# Android emulator: http://10.0.2.2:3000  |  iOS simulator: http://localhost:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
