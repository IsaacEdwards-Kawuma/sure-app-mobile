# PostgreSQL (e.g. Neon). Copy to .env and set your connection string.
# On server start, migrations run automatically and create/update tables (users, sales, expenses, vouchers, assets, settings, admin_log).
# Verify: Start backend (cd backend && npm start), then open http://localhost:3000/api/health/db — you should see table counts. Sign up in the app to create a user row.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server
PORT=3000
NODE_ENV=development

# CORS (comma-separated origins; use * for development)
ALLOWED_ORIGINS=http://localhost:19006,*

# Optional: rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
