# Paste these into Render: Dashboard → Web Service → Environment → "Paste from .env"
# 1. Copy your DATABASE_URL from backend/.env (Neon connection string)
# 2. Replace JWT_SECRET with a long random string (e.g. from https://randomkeygen.com)
# 3. Copy the block below (no # lines) and paste into Render

DATABASE_URL=paste-your-neon-connection-string-from-backend-.env-here
JWT_SECRET=your-long-random-secret-change-this
NODE_ENV=production
ALLOWED_ORIGINS=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
